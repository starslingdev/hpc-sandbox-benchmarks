#!/usr/bin/env bash
#MISE description="PTS: GitHub archive download throughput + connection timing (custom local suite)"
# Measurement leaf: -e guards the scaffolding; the measured run is isolated by run_pts_benchmark.
# This wraps the repo-local github-download PTS profile (packages/schema/src/pts-profiles/local/
# github-download-1.0.0) the same way benchmark:realworld:pts:* wrap better-auth/mastra: install the
# local profile, then batch-run it. One curl download of a pinned GitHub archive posts four catalogued
# metrics — download speed (Mbit/s) plus connect latency, time-to-first-byte and DNS lookup (ms) —
# the fast-cli-style network numbers, over the github.com path every suite already clones from.
set -euo pipefail
REPO_ROOT="$(git -C "$(dirname "${BASH_SOURCE[0]}")" rev-parse --show-toplevel)"
source "${REPO_ROOT}/lib/bench.sh"

if ! command -v phoronix-test-suite &>/dev/null; then
	skip_result "phoronix-test-suite not installed" "pts_github-download"
	exit 0
fi
# The profile's runner IS curl — without it there is nothing to measure. Skip before install so a
# curl-less sandbox records the negative the normalizer expects instead of a failed install.
if ! command -v curl &>/dev/null; then
	skip_result "curl not installed" "pts_github-download"
	exit 0
fi

# Stage the repo-local profile (with its bundled install.sh) into PTS's local-profile dir, then let
# run_pts_benchmark install and batch-run it under the pts_github-download result prefix.
install_local_pts_profile "github-download-1.0.0"
run_pts_benchmark "local/github-download-1.0.0" "pts_github-download"

# PTS returns zero and writes a composite even when every trial failed (empty <Value>s). Treat the
# suite as successful only when all four result parsers emitted a numeric value — the same guard the
# fast-cli leaf uses, here catching a degraded egress path that would otherwise look green with no
# usable throughput/latency numbers.
result_xml="$(results_dir)/pts_github-download.xml"
if [ ! -s "$result_xml" ] || ! awk '
	match($0, /<Value>[^<]*<\/Value>/) {
		value = substr($0, RSTART + 7, RLENGTH - 15)
		if (value ~ /^[0-9]+([.][0-9]+)?$/) numeric++
	}
	END { exit numeric == 4 ? 0 : 1 }
' "$result_xml"; then
	echo "ERROR: local/github-download did not produce four numeric metrics" >&2
	exit 1
fi
