# better-auth/better-auth (ENG-136) -- consumed by lib/pts/realworld/realworld-runner.sh. One TASK_CMD_<value>
# per <Option>/<Menu>/<Entry>/<Value> in test-definition.xml (packages/schema/src/pts-profiles.test.ts
# asserts the two stay in lockstep). git_clone has no shell command: the runner measures it via a
# fixed git-fetch algorithm, not a package script.
#
# Phase isolation: lint:types and lint:package have turbo dependsOn ["^build","build"] with dist/**
# inputs -- upstream CI satisfies that by building first. The Task menu measures `build` once,
# early; a TASK_PREP_<value> task then keeps dist + turbo cache through its reset, so the
# unmeasured prep is a near-instant cache REPLAY of that measured build (full build only when the
# task runs standalone), and the timed `--only` command executes exactly the named task
# (TURBO_FORCE=true on the measured command keeps it a genuine execution, never a replay).
#
# No `test` task: upstream CI's test job requires docker-compose DB services (postgres,
# postgres-kysely, mongodb) before `pnpm test`; provider sandboxes have no docker daemon, so the
# task would fail on every provider and permanently zero the metric.
REPO_URL="https://github.com/better-auth/better-auth.git"
PIN_SHA="6f3ba45639579da152b69e8e5342e02f28288670"
NODE_VERSION="22"

TASK_CMD_git_clone=""
TASK_CMD_cold_install="pnpm install --frozen-lockfile"
TASK_CMD_lint_biome="pnpm lint"
TASK_CMD_lint_deps="pnpm lint:dependencies"
TASK_CMD_lint_format="pnpm format:check"
TASK_CMD_lint_spell="pnpm lint:spell"
TASK_PREP_lint_types="pnpm build"
TASK_CMD_lint_types="pnpm lint:types --only"
TASK_PREP_lint_packages="pnpm build"
TASK_CMD_lint_packages="pnpm lint:packages --only"
TASK_CMD_typecheck="pnpm typecheck"
TASK_CMD_build="pnpm build"
