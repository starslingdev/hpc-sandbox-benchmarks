# mastra-ai/mastra (ENG-137) -- consumed by lib/pts/realworld/realworld-runner.sh. One TASK_CMD_<value> per
# <Option>/<Menu>/<Entry>/<Value> in test-definition.xml (packages/schema/src/pts-profiles.test.ts
# asserts the two stay in lockstep). git_clone has no shell command: the runner measures it via a
# fixed git-fetch algorithm, not a package script. Scoped to packages/core per ENG-137 (build:core /
# test:core), not the full monorepo build/test.
REPO_URL="https://github.com/mastra-ai/mastra.git"
PIN_SHA="b6eeb9d08ebeaf27bc6fd16b6b88087040aaf767"
NODE_VERSION="22"

TASK_CMD_git_clone=""
TASK_CMD_cold_install="pnpm install --frozen-lockfile"
TASK_CMD_lint_format="pnpm lint:format"
TASK_CMD_build_core="pnpm build:core"
TASK_CMD_test_core="pnpm test:core"
